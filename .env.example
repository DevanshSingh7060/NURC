# Copy to .env and fill in real values. .env is gitignored — never commit secrets.

# --- Admin scraper (scrape-admin.mjs) — Node-only, NOT exposed to the client bundle ---
# Credentials for the super_admin portal used by the reference-scraping helper.
# Run with: node --env-file=.env scrape-admin.mjs
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-admin-password

# --- Frontend dev/demo seed (VITE_ vars ARE embedded into the client bundle) ---
# Password for the seeded demo subscriber shown in dev/preview.
# Dev/preview only — leave UNSET in real production so no default login ships.
VITE_DEV_SEED_PASSWORD=change-me-dev-only

# --- Backend API (optional) ---
# Base URL for a real backend. When UNSET, the app uses the built-in mock client
# (src/app/lib/mock.ts) — forms validate and show real submit states but persist nothing.
# Set this to switch every typed api.* call to real HTTP with no code changes.
# VITE_API_BASE_URL=https://api.example.com
